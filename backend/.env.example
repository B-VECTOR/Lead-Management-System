# Copy to .env and adjust for your environment.

# SECURITY WARNING: generate a real key for anything but local dev:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-before-deploying-to-production

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL connection. Must match a database/role that exists locally.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lms

# Origins allowed to call the API from the browser (the Vite dev server).
# Comma-separated. Defaults to the local Vite dev server if unset.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
